{
  "name": "@inmanta/web-console",
  "version": "3.1.0",
  "description": "Web Console for Inmanta Orchestrator",
  "exports": "./dist/index.js",
  "repository": "https://github.com/inmanta/web-console.git",
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "yarn clean",
    "build": "vite build",
    "build:ci": "node --max-old-space-size=6144 ./node_modules/.bin/vite build",
    "start": "dotenv vite",
    "start:https": "HTTPS=true dotenv vite",
    "test": "vitest --run",
    "test:ci": "CI=true vitest --silent",
    "test:ui": "vitest --ui",
    "format": "prettier --check --write \"./**/*.{cjs,js,jsx,ts,tsx}\"",
    "format:check": "prettier --check \"./**/*.{cjs,js,jsx,ts,tsx}\"",
    "lint": "eslint --max-warnings=0 -c eslint.config.js",
    "lint:fix": "eslint --max-warnings=0  --quiet --fix",
    "build:bundle-profile": "vite build --mode analyze",
    "bundle-profile:analyze": "yarn build:bundle-profile",
    "clean": "rimraf dist",
    "delete:reports": "rm -r cypress/reports/* || true",
    "precypress-test": "yarn run delete:reports",
    "cypress-test:oss": "yarn cypress run --config-file cypress.config.oss.cjs",
    "cypress-test:iso": "yarn cypress run",
    "cypress-test:keycloak": "yarn cypress run --config-file cypress.config.keycloak.cjs",
    "cypress-test:local-auth": "yarn cypress run --config-file cypress.config.local-auth.cjs",
    "cypress-test:oidc": "yarn cypress run --config-file cypress.config.oidc.cjs",
    "package-cleanup": "node clean_up_packages",
    "check-circular-deps": "madge --circular ./src/index.tsx",
    "check-no-cdn": "node scripts/check-no-cdn.js",
    "install:orchestrator:keycloak": "sh ./shell-scripts/setup-auth.sh version='oss' release='dev' branch='oss_case_1'",
    "install:orchestrator:oidc": "sh ./shell-scripts/setup-auth.sh version='oss' release='dev' branch='oss_case_1' auth='oidc'",
    "install:orchestrator:local-auth": "sh ./shell-scripts/setup-auth.sh version='oss' release='dev' branch='oss_case_1' auth='localauth'",
    "install:orchestrator": "sh ./shell-scripts/setup-orchestrator.sh flag='-ti'",
    "install:orchestrator:iso": "sh ./shell-scripts/setup-orchestrator.sh flag='-ti'",
    "install:orchestrator:pxsdc": "sh ./shell-scripts/setup-orchestrator.sh flag='-ti' project='pxsdc'",
    "install:orchestrator:oss": "sh ./shell-scripts/setup-orchestrator.sh flag='-ti' version='oss' release='dev' branch='oss_case_1'",
    "install:orchestrator:ci": "sh ./shell-scripts/setup-orchestrator.sh",
    "kill-server": "sh ./shell-scripts/clear-server.sh",
    "update:dist": "docker exec -u root inmanta_orchestrator rm -rf /usr/share/inmanta/web-console && docker cp dist inmanta_orchestrator:/usr/share/inmanta/web-console"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --check --write"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@remix-run/router": "^1.23.2",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest-axe": "^3.5.9",
    "@types/loadable__component": "^5.13.10",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "cypress": "^15.14.1",
    "cypress-file-upload": "^5.0.8",
    "cypress-multi-reporters": "^2.0.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^16.5.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "madge": "^6.1.0",
    "markdown-it-emoji": "^3.0.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.4",
    "mochawesome-report-generator": "^6.3.2",
    "msw": "^2.13.5",
    "prettier": "^3.8.3",
    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.1.3",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vite-plugin-mkcert": "^1.17.12",
    "vite-plugin-monaco-editor-esm": "^2.0.2",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "browser": {
    "crypto": false
  },
  "dependencies": {
    "@graphiql/react": "^0.37.3",
    "@joint/layout-directed-graph": "^4.2.3",
    "@joint/plus": "^4.2.3",
    "@loadable/component": "^5.16.7",
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-code-editor": "^6.4.3",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-log-viewer": "^6.3.0",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@patternfly/react-tokens": "^6.4.0",
    "@react-keycloak/web": "^3.4.0",
    "@tanstack/react-query": "^5.100.1",
    "bignumber.js": "^11.0.0",
    "copy-to-clipboard": "^4.0.0",
    "file-saver": "^2.0.5",
    "graphiql": "^5.2.2",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "highlight.js": "^11.11.1",
    "keycloak-js": "^26.2.4",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "monaco-editor": "^0.52.2",
    "oidc-client-ts": "^3.5.0",
    "process": "^0.11.10",
    "qs": "^6.15.1",
    "react": "^19.2.5",
    "react-diff-viewer-continued": "^3.4.0",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.5",
    "react-oidc-context": "^3.3.1",
    "react-router": "^7.14.1",
    "styled-components": "^6.4.0",
    "uuid": "^14.0.0",
    "victory": "^37.3.6",
    "xml-formatter": "^3.7.0"
  },
  "resolutions": {
    "cookie": "^0.7.0",
    "follow-redirects": "^1.15.4",
    "glob": "^10.5.0",
    "glob-parent": "^5.1.2",
    "json-schema": "^0.4.0",
    "json5": "^2.2.2",
    "loader-utils": "2.0.4 || 1.4.2",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "micromatch": "^4.0.8",
    "minimatch@^3": "3.1.3",
    "minimatch@^9": "9.0.7",
    "minimist": "^1.2.6",
    "nanoid": "^3.3.8",
    "node-forge": "^1.0.0",
    "nth-check": "^2.0.1",
    "path-to-regexp@^6.2.0": "8.0.0",
    "prismjs": "^1.30.0",
    "rollup": "^4.59.0",
    "serialize-javascript": "^7.0.3",
    "simple-git": "^3.5.0",
    "tar": "^7.5.8",
    "word-wrap": "^1.2.4",
    "ws": "^8.17.1",
    "@babel/runtime": "^7.26.10",
    "http-proxy-middleware": "^2.0.8",
    "form-data": "^2.5.5"
  },
  "madge": {
    "fileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx"
    ],
    "tsConfig": "./tsconfig.json",
    "layout": "dot"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari versions"
  ],
  "packageManager": "yarn@4.1.0"
}
